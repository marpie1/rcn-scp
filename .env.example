# Copy this file to .env and fill in your values before running docker compose up

# Anthropic API key — required for AI pre-visit chat (scp-chat)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: set a bearer token to protect proxy API endpoints
SODOTO_PROXY_SECRET=

# Optional: change default ports (3000, 3001, 8765)
# WIKI_PORT=3000
# GROOVE_PORT=3001
# PROXY_PORT=8765
